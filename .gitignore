# ── 환경변수 / 민감 정보 ──────────────────────────────────────────────────────
.env
*.env
.env.*
.history/

# ── Python 가상환경 ───────────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python 캐시 ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── PyInstaller 빌드 결과물 ───────────────────────────────────────────────────
dist/
build/
*.spec

# ── 런타임 로그 / 임시 파일 ───────────────────────────────────────────────────
*.log
*.tmp
*.bak

# ── IDE / 에디터 설정 ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Windows 시스템 파일 ───────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
